{
  "name": "hono-production-app",
  "private": true,
  "type": "module",
  "module": "dashboard.ts",
  "scripts": {
    "dev": "wrangler dev --live-reload",
    "deploy": "wrangler deploy --minify",
    "build": "wrangler deploy --dry-run --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "tailwind": "tailwindcss -i ./assets/tailwind.css -o ./assets/statics/tailwind_generated.css --watch",
    "routes": "hono-router src/routes src/router.ts",
    "test": "echo \"Warning: No tests specified\" && exit 0",
    "drizzle": "drizzle-kit generate",
    "migrate-local": "wrangler d1 migrations apply 'database' --local",
    "migrate": "wrangler d1 migrations apply 'database' --remote",
    "populate": "wrangler d1 execute 'database' --local --file='seeds/seed.sql'",
    "delete": "wrangler d1 execute 'database' --local --file='src/models/deleteTables.sql'",
    "delete-data": "wrangler d1 execute 'database' --local --file='src/models/deleteDBdata.sql'",
    "lint": "bun ./node_modules/eslint/bin/eslint.js .",
    "lint:fix": "bun ./node_modules/eslint/bin/eslint.js . --fix"
  },
  "dependencies": {
    "@oslojs/crypto": "^1.0.1",
    "@tailwindcss/cli": "^4.1.17",
    "@tailwindcss/vite": "^4.1.18",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.11.4",
    "hono-router": "^1.2.0",
    "resend": "^6.9.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/bun": "^1.3.9",
    "@types/node": "^24.10.1",
    "daisy-jsx": "^2.1.2",
    "drizzle-kit": "^0.31.7",
    "eslint": "^10.0.3",
    "globals": "^16.5.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0",
    "wrangler": "^4.4.0"
  }
}